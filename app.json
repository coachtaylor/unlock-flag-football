{
  "expo": {
    "name": "Unlock Flag Football",
    "slug": "unlock-flag-football",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "unlock",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "bundleIdentifier": "com.unlockflagfootball.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.unlockflagfootball.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Unlock uses your photos so you can set a player's profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
